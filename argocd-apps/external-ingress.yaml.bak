apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: external-ingress
  namespace: argocd
spec:
  project: default

  source:
    repoURL: https://git.onlionel.com/lionel/k3s_gitops.git
    targetRevision: main
    path: apps/external-ingress

  destination:
    server: https://kubernetes.default.svc
    namespace: rev-proxy

  syncPolicy:
    automated:
      prune: true
      selfHeal: true

    syncOptions:
      - CreateNamespace=true